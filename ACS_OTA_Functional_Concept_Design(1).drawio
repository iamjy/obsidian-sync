        <mxCell id="e40" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#5B6573;strokeWidth=2;dashed=0;endArrow=block;endFill=1;startArrow=none;startFill=1;fontFamily=Noto Sans KR;fontSize=13;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="v37" target="v39">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="v41" value="&lt;b&gt;6&lt;/b&gt;&lt;br&gt;Bundle Commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CBE8D7;strokeColor=#3A8A61;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=14;fontStyle=0;align=center;verticalAlign=middle;spacing=8;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1555" y="930" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e42" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#5B6573;strokeWidth=2;dashed=0;endArrow=block;endFill=1;startArrow=none;startFill=1;fontFamily=Noto Sans KR;fontSize=13;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="v39" target="v41">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="v43" value="&lt;b&gt;핵심 제약&lt;/b&gt;&lt;br&gt;Slot B에서 새 Driver가 올라온 상태로 Peripheral FW를 갱신하되, Update Adapter는 구 FW도 읽고 복구할 수 있어야 합니다. 이 “Transition 호환성”이 보장되지 않으면 Jetson/Peripheral을 하나의 원자적 Transaction으로 묶기 어렵습니다." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#C59A14;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=12;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
