        <mxCell id="AiPad" value="iPad (현장) : App으로 장비 제어·영상" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="548" width="220" height="48" as="geometry" />
        </mxCell>

        <mxCell id="Afoot" value="판단 포인트 (Case A)&#10;+ 배포 통제·책임이 제조사(제이시스)에 집중 → 의료기기 규제/추적성 관점 명확&#10;+ 서버 인프라·보안·운영 비용을 발주사가 부담&#10;− 우리 → 제이시스 릴리스 전달 인터페이스(패키지 규격·서명키 소유) 합의 필요&#10;− 발주사에 서버 운영 역량 필요 / 계약 종료 후 이관 부담은 작음" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="50" y="608" width="660" height="178" as="geometry" />
        </mxCell>

        <mxCell id="eA_submit" value="앱 제출" style="html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="AJ1" target="AStore"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eA_install" value="iPad 앱 설치·업데이트 (App Store 경유)" style="html=1;endArrow=block;dashed=1;strokeColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="AStore" target="AiPad"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="304" y="300" /><mxPoint x="368" y="300" /><mxPoint x="368" y="534" /><mxPoint x="600" y="534" /></Array></mxGeometry></mxCell>
