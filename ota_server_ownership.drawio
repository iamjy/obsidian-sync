        <mxCell id="B_SERVER" value="★ OTA 서버 구축·운영 (Case B : 수탁사 소유, self-hosted 인프라 확장) — 장비 펌웨어 전용" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=3;fontStyle=1;fontSize=12;" vertex="1" parent="1">
