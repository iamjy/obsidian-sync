        <mxCell id="Ab3" value="ACS 장비 (현장/병원) :  펌웨어 업데이트 수신·검증·적용 (Phase A/B · 롤백)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fbe6e5;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="548" width="430" height="48" as="geometry" />
