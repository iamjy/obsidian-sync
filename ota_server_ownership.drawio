        <mxCell id="BiPad" value="iPad (현장) : App으로 장비 제어·영상" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1230" y="548" width="220" height="48" as="geometry" />
        </mxCell>

        <mxCell id="Bfoot" value="판단 포인트 (Case B)&#10;+ 파이프라인 ~ 서버 end-to-end 일관성, 빠른 배포·핫픽스&#10;+ 발주사는 서버 운영 부담 없이 배포 승인·모니터링만&#10;− 서버 운영·SLA·유지보수를 수탁사가 지속 부담 → 별도 운영 계약(비용/기간) 필요&#10;− 서버가 우리 인프라 경계 내 → 제이시스 데이터·접근권한·보안 합의 필요&#10;− 계약 종료 시 서버·키·데이터 이관 계획 필요 / 배포 최종 승인은 제조사(제이시스) 권장" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="790" y="608" width="660" height="178" as="geometry" />
        </mxCell>

