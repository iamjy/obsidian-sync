<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram name="OTA-Server-Ownership" id="ota-ownership">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1520" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="OTA 업데이트 서버 소유·운영 주체 — 역할 관점 2가지 시나리오 (큰 그림)" style="text;html=1;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="10" width="1000" height="26" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="발주사=제이시스 메디컬(iPad 앱 개발) / 수탁사=우리 회사(ACS Camera+Beam 장비·펌웨어 개발). 미결정 쟁점은 &#39;OTA 서버를 누가 구축·운영하는가&#39; 뿐임." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="30" y="38" width="1200" height="18" as="geometry" />
        </mxCell>

        <mxCell id="common" value="공통 (두 시나리오 동일) :  ① iPad App = 제이시스 개발    ② ACS 장비·펌웨어(Jetson/DLPC/ITE)·Device-side OTA Agent = 우리 개발    ③ 바이너리 빌드·서명 = 우리 self-hosted 파이프라인 산출물    ④ iPad App 배포·업데이트 = Apple App Store (장비 펌웨어 OTA 서버와 별개 채널)   →   달라지는 것은 &#39;서버 소유/운영&#39; 뿐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;verticalAlign=middle;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="30" y="64" width="1440" height="66" as="geometry" />
        </mxCell>

        <!-- ============ PANEL A ============ -->
        <mxCell id="pA" value="Case A.  발주사(제이시스 메디컬)가 OTA 서버 구축 · 운영" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;verticalAlign=top;fontStyle=1;fontSize=13;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="30" y="145" width="700" height="655" as="geometry" />
        </mxCell>

        <mxCell id="Ab1" value="제이시스 메디컬 (발주사 · 제조사)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e6;strokeColor=#d79b00;verticalAlign=top;fontStyle=1;fontSize=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="185" width="660" height="150" as="geometry" />
        </mxCell>
        <mxCell id="AJ1" value="iPad App 개발" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="62" y="222" width="140" height="40" as="geometry" />
