        <mxCell id="eA_deploy" value="배포 (HTTPS)" style="html=1;endArrow=block;strokeColor=#9673a6;strokeWidth=2;exitX=0.85;exitY=1;entryX=0.85;entryY=0;" edge="1" parent="1" source="A_SERVER" target="Ab3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="603" y="540" /></Array></mxGeometry></mxCell>

        <!-- ============ PANEL B ============ -->
        <mxCell id="pB" value="Case B.  수탁사(우리 회사)가 OTA 서버 구축 · 운영" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;verticalAlign=top;fontStyle=1;fontSize=13;spacingTop=8;" vertex="1" parent="1">
