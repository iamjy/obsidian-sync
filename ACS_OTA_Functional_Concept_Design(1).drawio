        <mxCell id="v27" value="&lt;b&gt;Vendor ISP 방식&lt;/b&gt;&lt;br&gt;I²C/SPI/전용 Tool 여부는 보드·벤더 문서로 확정" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="270" y="685" width="435" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v28" value="• 정확한 Part Number / Revision&lt;br&gt;• FW Store 위치(내장/외장)&lt;br&gt;• ISP Entry / Reset / Address&lt;br&gt;• HDMI 출력 비활성" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="705" y="685" width="405" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v29" value="• Chip ID / FW Version / Checksum&lt;br&gt;• HDMI Link / EDID / Resolution&lt;br&gt;• Warm/Cold Boot 반복" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1110" y="685" width="350" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v30" value="&lt;b&gt;TBD:&lt;/b&gt; Dual Bank / Readback / Recovery Mode&lt;br&gt;불가 시 Golden Image + 현장 ISP 경로 요구" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1460" y="685" width="410" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v31" value="&lt;b&gt;권고 Transaction 순서&lt;/b&gt;" style="shape=text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;spacing=0;" vertex="1" parent="1">
