        <mxCell id="v37" value="&lt;b&gt;4&lt;/b&gt;&lt;br&gt;DLPC / ITE Update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9E1F5;strokeColor=#76549A;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=14;fontStyle=0;align=center;verticalAlign=middle;spacing=8;dashed=0;shadow=0;" vertex="1" parent="1">
