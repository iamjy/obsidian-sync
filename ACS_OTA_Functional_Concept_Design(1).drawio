        <mxCell id="v51" value="&lt;b&gt;D. Health Check 실패&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8D7DA;strokeColor=#B94A55;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;spacing=8;dashed=0;shadow=0;" vertex="1" parent="1">
