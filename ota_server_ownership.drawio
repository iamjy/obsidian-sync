          <mxGeometry x="558" y="222" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="A_SERVER" value="★ OTA 서버 구축·운영·인프라/보안 (Case A : 발주사 소유) — 장비 펌웨어 전용" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=3;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="62" y="278" width="636" height="46" as="geometry" />
