        <mxCell id="e38" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#5B6573;strokeWidth=2;dashed=0;endArrow=block;endFill=1;startArrow=none;startFill=1;fontFamily=Noto Sans KR;fontSize=13;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="v35" target="v37">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="v39" value="&lt;b&gt;5&lt;/b&gt;&lt;br&gt;E2E Health Check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6E9ED;strokeColor=#66717E;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=14;fontStyle=0;align=center;verticalAlign=middle;spacing=8;dashed=0;shadow=0;" vertex="1" parent="1">
