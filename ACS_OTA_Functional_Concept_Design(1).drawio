        <mxCell id="v52" value="&lt;b&gt;예시&lt;/b&gt;&lt;br&gt;• Video Stream 없음&lt;br&gt;• Control 응답 Timeout&lt;br&gt;• DLPC Status 오류&lt;br&gt;• HDMI Link/EDID 실패&lt;br&gt;• Watchdog Reset 반복" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8D7DA;strokeColor=#B94A55;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=top;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1645" y="370" width="225" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="e53" value="검증 실패" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#B94A55;strokeWidth=2;dashed=1;endArrow=block;endFill=1;startArrow=none;startFill=1;fontFamily=Noto Sans KR;fontSize=13;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1510" y="233" as="sourcePoint"/>
            <mxPoint x="1755" y="370" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="v54" value="&lt;b&gt;Rollback Transaction&lt;/b&gt;&lt;br&gt;Peripheral 복원 가능 여부 확인 → Jetson A 복귀 → 서비스 재검증 → 실패 보고" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#C59A14;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=center;verticalAlign=middle;spacing=8;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1645" y="570" width="225" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="v55" value="&lt;b&gt;전원 차단 / 강제 Reset 시 공통 규칙&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 상태 단계·대상 Component·마지막 성공 Chunk를 Persistent Metadata에 기록&lt;br&gt;• 재부팅 후 “중단 지점 재개” 또는 “안전 Rollback”을 결정&lt;br&gt;• DLPC/ITE Single-Bank Erase 중 전원 차단은 자동 복구가 불가능할 수 있으므로 외부 전원·Hold-up·Service ISP를 설계 조건으로 요구" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#C59A14;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=14;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="55" y="805" width="1130" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="v56" value="&lt;b&gt;iPad Disconnect&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Update는 중단하지 않음&lt;br&gt;• ACS가 독립 진행&lt;br&gt;• 재접속 시 /ota/status 또는 Event Stream으로 상태 복구&lt;br&gt;• Operator에게 최종 Audit ID 제공" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9EAF7;strokeColor=#3B78A6;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=14;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1215" y="805" width="310" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="v57" value="&lt;b&gt;복구 불능 판단&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Controller가 Boot/ISP Mode 진입 불가&lt;br&gt;• Flash ID/Bus 응답 없음&lt;br&gt;• Golden Image 없음&lt;br&gt;• 지정 Retry 횟수 초과&lt;br&gt;→ 장비 기능 잠금 + 서비스 코드 표시" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8D7DA;strokeColor=#B94A55;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=14;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1555" y="805" width="315" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="e58" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#B8C0C8;strokeWidth=1;dashed=0;endArrow=none;endFill=1;startArrow=none;startFill=1;fontFamily=Noto Sans KR;fontSize=13;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="35" y="1042" as="sourcePoint"/>
            <mxPoint x="1885" y="1042" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="v59" value="제안안 v0.1 · 기능/개념 설계 수준 · 상세 인터페이스는 HW/벤더 문서 확인 필요" style="shape=text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontColor=#66717E;fontFamily=Noto Sans KR;fontSize=11;fontStyle=0;align=left;verticalAlign=middle;spacing=0;" vertex="1" parent="1">
