        <mxCell id="v11" value="① Jetson OS / BSP / App" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DDF1E6;strokeColor=#3A8A61;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="45" y="181" width="225" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v12" value="&lt;b&gt;Image-based A/B&lt;/b&gt;&lt;br&gt;Inactive Slot에 전체 Image 기록&lt;br&gt;Pending Boot 후 Commit" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="270" y="181" width="435" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v13" value="• 저장 공간/Partition Layout 확보&lt;br&gt;• Board ID·BSP·Bootloader 호환&lt;br&gt;• OTA Agent가 양 Slot에서 기동" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="705" y="181" width="405" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v14" value="• 새 Slot Boot&lt;br&gt;• OTA Agent/Watchdog 정상&lt;br&gt;• 기본 Device API 응답" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1110" y="181" width="350" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v15" value="&lt;b&gt;자동:&lt;/b&gt; Boot Attempt 초과 시 Slot A 복귀&lt;br&gt;Last-good Slot은 Commit 전 덮어쓰지 않음" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1460" y="181" width="410" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v16" value="② AP-side Driver" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DDF1E6;strokeColor=#3A8A61;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="45" y="349" width="225" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v17" value="&lt;b&gt;Jetson Image와 동시 배포&lt;/b&gt;&lt;br&gt;Kernel Module·DTB·User-space Adapter 포함" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="270" y="349" width="435" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v18" value="• 신규 Driver가 “현재 FW + 목표 FW”를 모두 지원하거나&lt;br&gt;• Full Driver와 분리된 Low-level Transition Updater 제공" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="705" y="349" width="405" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v19" value="• Device Probe / Bus Access&lt;br&gt;• Firmware ID Read&lt;br&gt;• 기본 Command/Status" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1110" y="349" width="350" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v20" value="Jetson Slot Rollback으로 Driver 복귀&lt;br&gt;단, Peripheral FW도 호환 버전으로 복원되어야 함" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1460" y="349" width="410" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v21" value="③ DLPC SPI Flash FW" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E9E1F5;strokeColor=#76549A;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="45" y="517" width="225" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v22" value="&lt;b&gt;Maintenance + Boot/Update Mode&lt;/b&gt;&lt;br&gt;Beam OFF → Reset/Hold → Erase/Program → Verify" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="270" y="517" width="435" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v23" value="• 정확한 DLPC 모델/Flash Map&lt;br&gt;• 보정 데이터 분리 여부&lt;br&gt;• SPI Ownership / Reset Sequence&lt;br&gt;• 외부 전원 고정" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="705" y="517" width="405" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v24" value="• Flash ID / Readback / Checksum&lt;br&gt;• FW Version / Controller Status&lt;br&gt;• Beam 출력 안전 테스트" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1110" y="517" width="350" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v25" value="&lt;b&gt;권고:&lt;/b&gt; Current FW Backup 또는 Golden Image&lt;br&gt;Single Bank이면 Service Header/Programmer 필수" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AEB6BE;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=0;align=left;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="1460" y="517" width="410" height="168" as="geometry"/>
        </mxCell>
        <mxCell id="v26" value="④ ITE6810FN FW" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E9E1F5;strokeColor=#76549A;fontColor=#1F2933;fontFamily=Noto Sans KR;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=10;dashed=0;shadow=0;" vertex="1" parent="1">
